{
  "version": 3,
  "configurePresets": [
    {
      "name": "Coroutine",
      "displayName": "Debug coroutine build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build_coroutine",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CANOPY_LOGGING_LEVEL": "1",
        "CANOPY_USE_LOGGING": "ON",
        "CANOPY_ADD_REF_COUNT_CHECKS": "OFF",
        "CANOPY_ASSERT_ON_LOGGER_ERROR": "OFF",
        "CANOPY_BUILD_BENCHMARKING": "ON",
        "CANOPY_BUILD_COROUTINE": "OFF",
        "CANOPY_BUILD_DEMOS": "ON",
        "CANOPY_BUILD_ENCLAVE": "OFF",
        "CANOPY_BUILD_TEST": "ON",
        "CANOPY_DEBUG_ADDRESS": "OFF",
        "CANOPY_DEBUG_ALL": "OFF",
        "CANOPY_VERBOSE_GENERATOR": "OFF",
        "CANOPY_DEBUG_LEAK": "OFF",
        "CANOPY_DEBUG_THREAD": "OFF",
        "CANOPY_DEBUG_UNDEFINED": "OFF",
        "CANOPY_ENABLE_CLANG_TIDY_FIX": "OFF",
        "CANOPY_ENABLE_CLANG_TIDY": "OFF",
        "CANOPY_ENABLE_COVERAGE": "OFF",
        "CANOPY_HANG_ON_FAILED_ASSERT": "OFF",
        "CANOPY_STANDALONE": "ON",
        "CANOPY_USE_CONSOLE_TELEMETRY": "OFF",
        "CANOPY_USE_TELEMETRY_RAII_LOGGING": "OFF",
        "CANOPY_USE_TELEMETRY": "OFF",
        "CANOPY_USE_THREAD_LOCAL_LOGGING": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_RULE_MESSAGES": "OFF",
        "CMAKE_VERBOSE_MAKEFILE": "OFF",
        "LIBCORO_BUILD_EXAMPLES": "OFF",
        "LIBCORO_BUILD_TESTS": "OFF",
        "LIBCORO_EXTERNAL_DEPENDENCIES": "OFF",
        "LIBCORO_FEATURE_NETWORKING": "OFF",
        "LIBCORO_FEATURE_TLS": "OFF"
      }
    },
    {
      "name": "Release_Coroutine",
      "displayName": "Release coroutine build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build_release_coroutine",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CANOPY_LOGGING_LEVEL": "2",
        "CANOPY_USE_LOGGING": "ON",
        "CANOPY_ADD_REF_COUNT_CHECKS": "OFF",
        "CANOPY_ASSERT_ON_LOGGER_ERROR": "OFF",
        "CANOPY_BUILD_BENCHMARKING": "ON",
        "CANOPY_BUILD_COROUTINE": "OFF",
        "CANOPY_BUILD_DEMOS": "ON",
        "CANOPY_BUILD_ENCLAVE": "OFF",
        "CANOPY_BUILD_TEST": "ON",
        "CANOPY_DEBUG_ADDRESS": "OFF",
        "CANOPY_DEBUG_ALL": "OFF",
        "CANOPY_VERBOSE_GENERATOR": "OFF",
        "CANOPY_DEBUG_LEAK": "OFF",
        "CANOPY_DEBUG_THREAD": "OFF",
        "CANOPY_DEBUG_UNDEFINED": "OFF",
        "CANOPY_ENABLE_CLANG_TIDY_FIX": "OFF",
        "CANOPY_ENABLE_CLANG_TIDY": "OFF",
        "CANOPY_ENABLE_COVERAGE": "OFF",
        "CANOPY_HANG_ON_FAILED_ASSERT": "OFF",
        "CANOPY_STANDALONE": "ON",
        "CANOPY_USE_CONSOLE_TELEMETRY": "OFF",
        "CANOPY_USE_TELEMETRY_RAII_LOGGING": "OFF",
        "CANOPY_USE_TELEMETRY": "OFF",
        "CANOPY_USE_THREAD_LOCAL_LOGGING": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_RULE_MESSAGES": "OFF",
        "CMAKE_VERBOSE_MAKEFILE": "OFF",
        "LIBCORO_BUILD_EXAMPLES": "OFF",
        "LIBCORO_BUILD_TESTS": "OFF",
        "LIBCORO_EXTERNAL_DEPENDENCIES": "OFF",
        "LIBCORO_FEATURE_NETWORKING": "OFF",
        "LIBCORO_FEATURE_TLS": "OFF"
      }
    }
  ]
}